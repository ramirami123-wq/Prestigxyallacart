        "liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>Jolie Detox Patches — Wake Up Lighter</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --ink: #2c2420;\n    --cream: #FFFDF9;\n    --warm: #c9836a;\n    --warm-dark: #a8654d;\n    --sand: #f3ece4;\n    --sand-mid: #e3d6c8;\n    --text-soft: #7a6f66;\n    --green: #8a9b6e;\n    --gold: #d9a566;\n    --serif: 'Georgia', 'Times New Roman', serif;\n    --sans: 'Helvetica Neue', Arial, sans-serif;\n  }\n\n  body {\n    font-family: var(--sans);\n    color: var(--ink);\n    background: var(--cream);\n    line-height: 1.6;\n  }\n\n  /* ── CUSTOMER COUNT BANNER ── */\n  .customer-banner {\n    background: var(--ink);\n    color: var(--cream);\n    padding: 16px 20px;\n    text-align: center;\n    font-size: 15px;\n    font-weight: 600;\n    letter-spacing: 0.4px;\n  }\n  .customer-banner span { color: var(--gold); }\n\n  /* ── SECTION TITLES ── */\n  .section-title {\n    font-family: var(--serif);\n    font-style: italic;\n    font-size: 30px;\n    font-weight: 400;\n    text-align: center;\n    margin-bottom: 12px;\n    letter-spacing: 0.3px;\n  }\n  .section-subtitle {\n    text-align: center;\n    color: var(--text-soft);\n    font-size: 16px;\n    margin: 0 auto 50px;\n    max-width: 600px;\n  }\n\n  /* ── FEATURES GRID ── */\n  .features-section {\n    background: var(--sand);\n    padding: 72px 20px;\n  }\n  .features-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n    gap: 24px;\n    max-width: 1000px;\n    margin: 0 auto;\n  }\n  .feature-card {\n    background: var(--cream);\n    border-radius: 16px;\n    padding: 32px 24px;\n    text-align: center;\n    border: 1px solid var(--sand-mid);\n  }\n  .feature-icon {\n    width: 56px;\n    height: 56px;\n    margin: 0 auto 18px;\n    color: var(--warm);\n  }\n  .feature-icon svg { width: 100%; height: 100%; display: block; }\n  .feature-card h3 {\n    font-size: 14px;\n    font-weight: 700;\n    margin-bottom: 8px;\n    letter-spacing: 0.4px;\n  }\n  .feature-card p {\n    font-size: 13px;\n    color: var(--text-soft);\n  }\n\n  /* ── FEEL SECTION ── */\n  .feel-section { padding: 80px 20px; background: var(--cream); }\n  .feel-inner {\n    max-width: 1000px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 56px;\n    align-items: center;\n  }\n  .feel-img img {\n    width: 100%;\n    border-radius: 16px;\n    object-fit: cover;\n    height: 500px;\n    display: block;\n  }\n  .feel-text h2 {\n    font-family: var(--serif);\n    font-style: italic;\n    font-size: 32px;\n    font-weight: 400;\n    margin-bottom: 20px;\n    line-height: 1.25;\n  }\n  .feel-text p {\n    font-size: 16px;\n    color: #5d534b;\n    margin-bottom: 20px;\n    line-height: 1.7;\n  }\n  .feel-text ul { list-style: none; padding: 0; }\n  .feel-text ul li {\n    padding: 11px 0;\n    font-size: 15px;\n    border-bottom: 1px solid var(--sand-mid);\n    display: flex;\n    align-items: flex-start;\n    gap: 10px;\n  }\n  .feel-text ul li::before {\n    content: \"✦\";\n    color: var(--warm);\n    font-weight: 700;\n    font-size: 14px;\n    flex-shrink: 0;\n    margin-top: 2px;\n  }\n  .feel-text ul li strong { font-weight: 700; }\n\n  /* ── TESTIMONIAL QUOTE ── */\n  .quote-box {\n    background: var(--sand);\n    border-left: 4px solid var(--warm);\n    padding: 24px 28px;\n    border-radius: 0 14px 14px 0;\n    margin-top: 32px;\n  }\n  .quote-box p {\n    font-style: italic;\n    font-size: 16px;\n    color: #4a423b;\n    margin-bottom: 12px;\n  }\n  .quote-author { display: flex; align-items: center; gap: 12px; }\n  .avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; }\n  .author-info strong { display: block; font-size: 14px; font-weight: 700; }\n  .author-info span { font-size: 12px; color: var(--text-soft); }\n  .stars { color: var(--gold); font-size: 14px; letter-spacing: 2px; }\n\n  /* ── HOW IT WORKS ── */\n  .how-section { background: var(--ink); padding: 80px 20px; color: var(--cream); }\n  .how-section .section-title { color: var(--cream); }\n  .how-section .section-subtitle { color: rgba(255,253,249,0.6); }\n  .how-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 24px;\n    max-width: 1000px;\n    margin: 0 auto;\n  }\n  .how-card {\n    background: rgba(255,253,249,0.05);\n    border: 1px solid rgba(255,253,249,0.12);\n    border-radius: 16px;\n    padding: 34px 24px;\n    text-align: center;\n  }\n  .how-card .icon-wrap {\n    width: 60px;\n    height: 60px;\n    background: var(--warm);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin: 0 auto 20px;\n    color: var(--cream);\n  }\n  .how-card .icon-wrap svg { width: 30px; height: 30px; }\n  .how-card h3 {\n    font-size: 15px;\n    font-weight: 700;\n    margin-bottom: 10px;\n    color: var(--cream);\n    letter-spacing: 0.4px;\n  }\n  .how-card p { font-size: 14px; color: rgba(255,253,249,0.65); line-height: 1.6; }\n\n  /* ── FEATURED IN ── */\n  .featured-section { padding: 44px 20px; background: var(--sand); text-align: center; }\n  .featured-label {\n    font-size: 12px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--text-soft);\n    margin-bottom: 22px;\n    font-weight: 600;\n  }\n  .featured-logos { max-width: 680px; margin: 0 auto; }\n  .featured-logos img { width: 100%; filter: grayscale(1) opacity(0.5); object-fit: contain; max-height: 46px; }\n\n  /* ── RESULTS / STATS ── */\n  .results-section { padding: 80px 20px; background: var(--cream); }\n  .results-inner {\n    max-width: 1000px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 56px;\n    align-items: center;\n  }\n  .results-img img { width: 100%; border-radius: 16px; height: 500px; object-fit: cover; display: block; }\n  .results-heading {\n    font-family: var(--serif);\n    font-style: italic;\n    font-size: 30px;\n    font-weight: 400;\n    margin-bottom: 36px;\n    line-height: 1.25;\n  }\n  .stats-list { display: flex; flex-direction: column; gap: 26px; }\n  .stat-item { display: flex; align-items: flex-start; gap: 20px; }\n  .stat-number {\n    font-family: var(--serif);\n    font-size: 50px;\n    font-weight: 700;\n    color: var(--warm);\n    line-height: 1;\n    flex-shrink: 0;\n    min-width: 92px;\n  }\n  .stat-desc { font-size: 15px; color: #5d534b; padding-top: 8px; line-height: 1.5; }\n  .stat-note { font-size: 12px; color: var(--text-soft); margin-top: 24px; font-style: italic; }\n\n  /* ── COMPARISON ── */\n  .compare-section { background: var(--sand); padding: 80px 20px; }\n  .compare-inner { max-width: 900px; margin: 0 auto; }\n  .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 40px; }\n  .compare-card {\n    background: var(--cream);\n    border-radius: 16px;\n    overflow: hidden;\n    border: 2px solid var(--sand-mid);\n  }\n  .compare-card.winner { border-color: var(--warm); }\n  .compare-card-header {\n    padding: 18px 24px;\n    font-size: 17px;\n    font-weight: 800;\n    letter-spacing: 0.4px;\n    background: var(--sand-mid);\n    color: var(--ink);\n  }\n  .compare-card.winner .compare-card-header { background: var(--warm); color: var(--cream); }\n  .compare-card-img { width: 100%; height: 190px; object-fit: contain; padding: 16px; background: #fbf7f1; display: block; }\n  .compare-list { list-style: none; padding: 20px 24px; }\n  .compare-list li {\n    padding: 9px 0;\n    font-size: 14px;\n    border-bottom: 1px solid #f1e9df;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .compare-list li:last-child { border-bottom: none; }\n  .check-green { color: var(--green); font-weight: 900; font-size: 16px; }\n  .check-red { color: var(--warm-dark); font-weight: 900; font-size: 16px; }\n\n  /* ── FAQ ── */\n  .faq-section { padding: 80px 20px; background: var(--cream); }\n  .faq-inner { max-width: 760px; margin: 0 auto; }\n  .faq-item { border-bottom: 1px solid var(--sand-mid); }\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 22px 0;\n    text-align: left;\n    font-size: 16px;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    color: var(--ink);\n    font-family: var(--sans);\n  }\n  .faq-question::after {\n    content: \"+\";\n    font-size: 22px;\n    font-weight: 300;\n    color: var(--warm);\n    transition: transform 0.2s;\n    flex-shrink: 0;\n    margin-left: 16px;\n  }\n  .faq-item.open .faq-question::after { transform: rotate(45deg); }\n  .faq-answer { display: none; padding: 0 0 20px; font-size: 15px; color: #5d534b; line-height: 1.7; }\n  .faq-item.open .faq-answer { display: block; }\n\n  /* ── GUARANTEE / BRAND ── */\n  .guarantee-section { background: var(--ink); color: var(--cream); padding: 80px 20px; text-align: center; }\n  .guarantee-inner { max-width: 900px; margin: 0 auto; }\n  .guarantee-section h2 {\n    font-family: var(--serif);\n    font-style: italic;\n    font-size: 30px;\n    font-weight: 400;\n    margin-bottom: 16px;\n    letter-spacing: 0.3px;\n  }\n  .guarantee-section .lead {\n    font-size: 17px;\n    color: rgba(255,253,249,0.75);\n    max-width: 640px;\n    margin: 0 auto 48px;\n    line-height: 1.7;\n  }\n  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 48px; }\n  .trust-card {\n    background: rgba(255,253,249,0.05);\n    border: 1px solid rgba(255,253,249,0.12);\n    border-radius: 14px;\n    padding: 26px 16px;\n  }\n  .trust-card .trust-icon { color: var(--warm); margin-bottom: 12px; }\n  .trust-card .trust-icon svg { width: 28px; height: 28px; }\n  .trust-card h4 { font-size: 13px; font-weight: 700; color: var(--cream); margin-bottom: 8px; letter-spacing: 0.3px; }\n  .trust-card p { font-size: 12px; color: rgba(255,253,249,0.5); margin: 0; }\n\n  /* ── CTA BAND ── */\n  .cta-band { background: var(--warm); padding: 56px 20px; text-align: center; }\n  .cta-band h2 {\n    font-family: var(--serif);\n    font-style: italic;\n    font-size: 28px;\n    font-weight: 400;\n    color: var(--cream);\n    margin-bottom: 24px;\n    letter-spacing: 0.4px;\n  }\n  .cta-btn {\n    display: inline-block;\n    background: var(--cream);\n    color: var(--warm-dark);\n    padding: 16px 44px;\n    border-radius: 50px;\n    font-size: 15px;\n    font-weight: 800;\n    text-decoration: none;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    transition: transform 0.15s, box-shadow 0.15s;\n  }\n  .cta-btn:hover { transform: scale(1.03); box-shadow: 0 8px 24px rgba(0,0,0,0.18); }\n\n  /* ── RESPONSIVE ── */\n  @media (max-width: 768px) {\n    .feel-inner, .results-inner { grid-template-columns: 1fr; }\n    .feel-img img, .results-img img { height: 320px; }\n    .how-grid { grid-template-columns: 1fr; }\n    .compare-grid { grid-template-columns: 1fr; }\n    .trust-grid { grid-template-columns: 1fr 1fr; }\n    .section-title { font-size: 25px; }\n    .stat-number { font-size: 40px; }\n  }\n</style>\n</head>\n<body>\n\n<!-- ── CUSTOMER COUNT ── -->\n<div class=\"customer-banner\">🌿 <span>21,000+</span> Happy Customers — Best Seller in Lebanon</div>\n\n<!-- ── FEATURES ── -->\n<section class=\"features-section\">\n  <div>\n    <p class=\"section-title\">A nightly ritual your feet will love</p>\n    <p class=\"section-subtitle\">Herbal overnight patches that support your body's natural detox — so you wake up feeling lighter, calmer and more refreshed.</p>\n    <div class=\"features-grid\">\n      <div class=\"feature-card\">\n        <div class=\"feature-icon\" aria-label=\"Supports Natural Detox\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"/>\n            <path d=\"M2 21c0-3 1.85-5.36 5.08-6\"/>\n          </svg>\n        </div>\n        <h3>Supports Natural Detox</h3>\n        <p>Activated herbs work overnight to support your body's own cleansing process.</p>\n      </div>\n      <div class=\"feature-card\">\n        <div class=\"feature-icon\" aria-label=\"Eases Tired Feet\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <path d=\"M4 16c-.5-2.5-.5-5.5 0-8C4.5 5 6 4 7.5 4.5 9 5 9.5 6.8 9.5 9c0 1.8.5 3 2 3.5 2 .7 3.5 2 3.5 4.2 0 2-1.6 3.3-3.6 3.3H7.5C5.5 20 4.3 18 4 16Z\"/>\n            <circle cx=\"16.5\" cy=\"6\" r=\"1.4\"/><circle cx=\"19\" cy=\"8.5\" r=\"1.2\"/><circle cx=\"19.5\" cy=\"12\" r=\"1.1\"/>\n          </svg>\n        </div>\n        <h3>Eases Tired, Heavy Feet</h3>\n        <p>Wake up to feet that feel softer, lighter and more relaxed after a long day.</p>\n      </div>\n      <div class=\"feature-card\">\n        <div class=\"feature-icon\" aria-label=\"Promotes Better Sleep\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <path d=\"M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z\"/>\n          </svg>\n        </div>\n        <h3>Promotes Better Sleep</h3>\n        <p>A calming herbal aroma turns winding down into a soothing bedtime ritual.</p>\n      </div>\n      <div class=\"feature-card\">\n        <div class=\"feature-icon\" aria-label=\"Feel Lighter and Refreshed\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <path d=\"M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1\"/>\n            <circle cx=\"12\" cy=\"12\" r=\"3\"/>\n          </svg>\n        </div>\n        <h3>Feel Lighter &amp; Refreshed</h3>\n        <p>Many wake with a noticeable \"lightness\" and a more comfortable start to the day.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── FEEL SECTION ── -->\n<section class=\"feel-section\">\n  <div class=\"feel-inner\">\n    <div class=\"feel-img\">\n     \n    </div>\n    <div class=\"feel-text\">\n      <h2>Unwind, detox and wake up lighter</h2>\n      <p>If your feet feel heavy after a long day on them, your sleep feels restless, or you just want a moment of calm that's truly yours — Jolie Detox Patches were made for you.</p>\n      <p>Rooted in a centuries-old Japanese cleansing tradition, our blend of <strong>bamboo vinegar, tourmaline and herbal extracts</strong> works gently overnight to support your body's natural detox — so mornings feel softer, calmer and more comfortable.</p>\n      <ul>\n        <li><div><strong>Supports natural detox</strong> — activated herbs work through the skin while you sleep, no effort required.</div></li>\n        <li><div><strong>Eases tired feet</strong> — soothes that heavy, restless feeling so you wake up relaxed.</div></li>\n        <li><div><strong>Calming bedtime ritual</strong> — a gentle herbal aroma helps you wind down for deeper rest.</div></li>\n        <li><div><strong>Lighter mornings</strong> — many feel a noticeable lightness and steadier start to the day.</div></li>\n        <li><div><strong>Effortless &amp; gentle</strong> — peel, place, sleep. Designed to be kind to sensitive skin.</div></li>\n      </ul>\n      <div class=\"quote-box\">\n        <p>\"I put them on before bed and by morning my feet feel so much lighter. It's become my favourite little self-care ritual — and I finally sleep through the night.\"</p>\n        <div class=\"quote-author\">\n          <img class=\"avatar\" src=\"data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='88' height='88'%3E%3Crect width='100%25' height='100%25' fill='%23e3d6c8'/%3E%3C/svg%3E\" alt=\"Verified buyer\" />\n          <div class=\"author-info\">\n            <strong>Maya K.</strong>\n            <span>Verified buyer</span>\n            <div class=\"stars\">★ ★ ★ ★ ★</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── HOW IT WORKS ── -->\n<section class=\"how-section\">\n  <p class=\"section-title\">How Jolie Patches work</p>\n  <p class=\"section-subtitle\">Three working layers in every patch, blended from natural ingredients.</p>\n  <div class=\"how-grid\">\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z\"/></svg>\n      </div>\n      <h3>Detox Shield™</h3>\n      <p>Bamboo vinegar, wood vinegar and loquat leaf support your body's natural overnight cleanse, leaving feet feeling fresher by morning.</p>\n    </div>\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 7v5l3 2\"/></svg>\n      </div>\n      <h3>Vitamin Core™</h3>\n      <p>Vitamin C, tourmaline and herbal extracts work gently through the night to ease that tired, heavy feeling and leave you refreshed.</p>\n    </div>\n    <div class=\"how-card\">\n      <div class=\"icon-wrap\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"3\"/><path d=\"M9 12l2 2 4-4\"/></svg>\n      </div>\n      <h3>Protective Matrix™</h3>\n      <p>An advanced backing keeps the patch secure and the active ingredients releasing steadily, so it stays comfortable all night.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── FEATURED IN ── -->\n\n\n<!-- ── RESULTS ── -->\n<section class=\"results-section\">\n  <div class=\"results-inner\">\n    <div class=\"results-img\">\n     \n    </div>\n    <div>\n      <h2 class=\"results-heading\">What customers notice</h2>\n      <div class=\"stats-list\">\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">9 in 10</div>\n          <p class=\"stat-desc\">Say their feet feel lighter and more relaxed within the first week of nightly use.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">88%</div>\n          <p class=\"stat-desc\">Report a calmer wind-down and more restful sleep with their nightly patch ritual.</p>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-number\">94%</div>\n          <p class=\"stat-desc\">Would recommend Jolie Detox Patches to a friend who wants a little more calm.</p>\n        </div>\n      </div>\n      <p class=\"stat-note\">*Based on customer feedback surveys. Individual results may vary.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── COMPARISON ── -->\n<section class=\"compare-section\">\n  <div class=\"compare-inner\">\n    <p class=\"section-title\">Why Jolie?</p>\n    <p class=\"section-subtitle\">A gentle, natural ritual — without the fuss of the alternatives.</p>\n    <div class=\"compare-grid\">\n      <div class=\"compare-card winner\">\n        <div class=\"compare-card-header\">✦ Jolie Detox Patches</div>\n        <img class=\"compare-card-img\" src=\"https://nuubu.com/theme/nuubu/og-image.jpg\" alt=\"Jolie Detox Patches\" />\n        <ul class=\"compare-list\">\n          <li><span class=\"check-green\">✓</span> 100% natural herbal blend</li>\n          <li><span class=\"check-green\">✓</span> Gentle on sensitive skin</li>\n          <li><span class=\"check-green\">✓</span> Effortless — works while you sleep</li>\n          <li><span class=\"check-green\">✓</span> Calming herbal aroma</li>\n          <li><span class=\"check-green\">✓</span> Free delivery across Lebanon</li>\n          <li><span class=\"check-green\">✓</span> Money-back guarantee</li>\n        </ul>\n      </div>\n      <div class=\"compare-card\">\n        <div class=\"compare-card-header\">✕ Other Methods</div>\n       \n        <ul class=\"compare-list\">\n          <li><span class=\"check-red\">✗</span> Harsh teas &amp; cleanses</li>\n          <li><span class=\"check-red\">✗</span> Messy soaks &amp; tubs</li>\n          <li><span class=\"check-red\">✗</span> Time-consuming routines</li>\n          <li><span class=\"check-red\">✗</span> No relaxing ritual</li>\n          <li><span class=\"check-red\">✗</span> Often shipped from abroad</li>\n          <li><span class=\"check-red\">✗</span> Limited or no guarantee</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── FAQ ── -->\n<section class=\"faq-section\">\n  <div class=\"faq-inner\">\n    <p class=\"section-title\">Frequently asked questions</p>\n    <p class=\"section-subtitle\" style=\"margin-bottom:40px;\">Everything you need to know before you order.</p>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\">How do Jolie Detox Patches work?</button>\n      <div class=\"faq-answer\">You apply a patch to the sole of each foot before bed. As you sleep, the natural herbal blend — bamboo vinegar, tourmaline and plant extracts — gently activates with the warmth and moisture of your skin to support your body's natural cleansing process. Peel them off in the morning.</div>\n    </div>\n    <div class=\"faq-item\">\n      <button class=\"faq-question\">Why does the patch turn darker overnight?</button>\n      <div class=\"faq-answer\">The herbal ingredients react with the natural moisture from your skin while you sleep, which causes the patch to change colour by morning. It's a normal part of how the patch works and varies from person to person.</div>\n    </div>\n    <div class=\"faq-item\">\n      <button class=\"faq-question\">How often should I use them?</button>\n      <div class=\"faq-answer\">Many people enjoy them as a nightly ritual, while others use them a few times a week to unwind. There's no limit — use them as often as feels good for you. Most notice the calming ritual feels best with consistent use.</div>\n    </div>\n    <div class=\"faq-item\">\n      <button class=\"faq-question\">Do they have a scent?</button>\n      <div class=\"faq-answer\">Yes — a natural, herbal aroma from the plant ingredients. There are no artificial perfumes added, which makes them suitable for sensitive skin.</div>\n    </div>\n    <div class=\"faq-item\">\n      <button class=\"faq-question\">Are they suitable for sensitive skin?</button>\n      <div class=\"faq-answer\">They're made with natural ingredients and no artificial scents. As with any topical product, if you have very sensitive skin or a known allergy, we'd suggest testing one patch first and discontinuing if any irritation occurs.</div>\n    </div>\n    <div class=\"faq-item\">\n      <button class=\"faq-question\">What are the delivery times in Lebanon?</button>\n      <div class=\"faq-answer\">We offer free delivery all across Lebanon, with most orders arriving within a few business days. You'll receive a confirmation as soon as your order is on its way.</div>\n    </div>\n    <div class=\"faq-item\">\n      <button class=\"faq-question\">What if I'm not happy with them?</button>\n      <div class=\"faq-answer\">Just reach out to our team and we'll make it right. Your satisfaction is backed by our money-back guarantee.</div>\n    </div>\n  </div>\n</section>\n\n<!-- ── GUARANTEE / BRAND ── -->\n<section class=\"guarantee-section\">\n  <div class=\"guarantee-inner\">\n    <h2>More than a patch — a moment for you</h2>\n    <p class=\"lead\">At Jolie, we believe self-care should feel effortless and beautiful. Jolie Detox Patches are a small nightly ritual that helps you unwind, reset, and wake up feeling lighter. Try them with confidence — backed by our money-back guarantee.</p>\n\n    <div class=\"trust-grid\">\n      <div class=\"trust-card\">\n        <div class=\"trust-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z\"/></svg></div>\n        <h4>Money-Back Guarantee</h4>\n        <p>Not in love with them? We'll make it right, no fuss.</p>\n      </div>\n      <div class=\"trust-card\">\n        <div class=\"trust-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z\"/></svg></div>\n        <h4>Here to Help</h4>\n        <p>A friendly team ready to answer any question you have.</p>\n      </div>\n      <div class=\"trust-card\">\n        <div class=\"trust-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2 9.2 8.6 2 9.2l5.5 4.7L5.8 21 12 17l6.2 4-1.7-7.1L22 9.2l-7.2-.6Z\"/></svg></div>\n        <h4>Natural Ingredients</h4>\n        <p>A herbal blend with no artificial scents or perfumes.</p>\n      </div>\n      <div class=\"trust-card\">\n        <div class=\"trust-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z\"/></svg></div>\n        <h4>Loved Locally</h4>\n        <p>Trusted by thousands across Lebanon and counting.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── CTA BAND ── -->\n<section class=\"cta-band\">\n  <h2>Wake up lighter. Start tonight.</h2>\n  <a href=\"#\" class=\"cta-btn\">Order Now</a>\n</section>\n\n<script>\n  document.querySelectorAll('.faq-question').forEach(btn => {\n    btn.addEventListener('click', () => {\n      const item = btn.closest('.faq-item');\n      const isOpen = item.classList.contains('open');\n      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));\n      if (!isOpen) item.classList.add('open');\n    });\n  });\n</script>\n\n</body>\n</html>",
