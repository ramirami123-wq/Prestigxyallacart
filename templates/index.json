er(entries=>{\n    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');}});\n  },{threshold:0.1});\n  els.forEach(el=>obs.observe(el));\n} else {\n  els.forEach(el=>el.classList.add('visible'));\n}\n</script>\n</body>\n</html>",
