case;color:var(--muted);margin-bottom:24px;}\n.g-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(165px,1fr));gap:12px;}\n.gc{border-radius:14px;padding:22px 18px;}\n.gc-icon{font-size:22px;margin-bottom:11px;}\n.gc-title{font-size:13px;font-weight:500;margin-bottom:5px;}\n.gc-body{font-size:12px;line-height:1.65;}\n.gc-free{background:var(--sage);}\n.gc-free .gc-title{color:#FDF8F2;}\n.gc-free .gc-body{color:rgba(253,248,242,0.75);}\n.gc-blush{background:var(--blush);}\n.gc-blush .gc-title{color:var(--blush-dark);}\n.gc-blush .gc-body{color:var(--blush-dark);opacity:0.85;}\n.gc-lav{background:var(--lavender);}\n.gc-lav .gc-title{color:var(--lavender-dark);}\n.gc-lav .gc-body{color:var(--lavender-dark);opacity:0.85;}\n.gc-sun{background:var(--sun);}\n.gc-sun .gc-title{color:var(--sun-dark);}\n.gc-sun .gc-body{color:var(--sun-dark);opacity:0.85;}\n\n/* ── SCROLL FADE IN ── */\n.fade-in{opacity:0;transform:translateY(22px);transition:opacity 0.6s ease,transform 0.6s ease;}\n.fade-in.visible{opacity:1;transform:translateY(0);}\n\n@media(prefers-reduced-motion:reduce){\n  .fade-in{opacity:1;transform:none;}\n  .marquee-track{animation:none;}\n}\n</style>\n</head>\n<body>\n\n<!-- ── MARQUEE ── -->\n<div class=\"marquee-wrap\" aria-hidden=\"true\">\n  <div class=\"marquee-track\">\n    <span>Cozy Vibes</span><span class=\"dot\">✦</span>\n    <span>Self Care</span><span class=\"dot\">✦</span>\n    <span>Spooky Cutie</span><span class=\"dot\">✦</span>\n    <span>The Little Cat</span><span class=\"dot\">✦</span>\n    <span>Chill Girl Vibes</span><span class=\"dot\">✦</span>\n    <span>Mystical Buddies</span><span class=\"dot\">✦</span>\n    <span>Cozy Cats</span><span class=\"dot\">✦</span>\n    <span>Spring Cuties</span><span class=\"dot\">✦</span>\n    <span>Girl Moments</span><span class=\"dot\">✦</span>\n    <span>Little Cuddles</span><span class=\"dot\">✦</span>\n    <span>Comfy Corner</span><span class=\"dot\">✦</span>\n    <span>Cozy Cottage Life</span><span class=\"dot\">✦</span>\n    <!-- Duplicate for seamless loop -->\n    <span>Cozy Vibes</span><span class=\"dot\">✦</span>\n    <span>Self Care</span><span class=\"dot\">✦</span>\n    <span>Spooky Cutie</span><span class=\"dot\">✦</span>\n    <span>The Little Cat</span><span class=\"dot\">✦</span>\n    <span>Chill Girl Vibes</span><span class=\"dot\">✦</span>\n    <span>Mystical Buddies</span><span class=\"dot\">✦</span>\n    <span>Cozy Cats</span><span class=\"dot\">✦</span>\n    <span>Spring Cuties</span><span class=\"dot\">✦</span>\n    <span>Girl Moments</span><span class=\"dot\">✦</span>\n    <span>Little Cuddles</span><span class=\"dot\">✦</span>\n    <span>Comfy Corner</span><span class=\"dot\">✦</span>\n    <span>Cozy Cottage Life</span><span class=\"dot\">✦</span>\n  </div>\n</div>\n\n<!-- ── HERO ── -->\n<section class=\"sec hero fade-in\">\n  <p class=\"hero-eyebrow\">Yallcart — colouring books for adults</p>\n  <h1 class=\"hero-h\">Your favorite screen-free ritual, <em>one page at a time</em></h1>\n  <p class=\"hero-sub\">Cute illustrations, thick pages, and that feeling of actually doing something with your hands. Made for adults who need a real break.</p>\n  <div class=\"hero-pills\">\n    <span class=\"pill pill-sage\">16+ designs</span>\n    <span class=\"pill pill-blush\">Perfect for gifting</span>\n    <span class=\"pill pill-lav\">Ships from Lebanon</span>\n    <span class=\"pill pill-sun\">Free delivery on $34+</span>\n  </div>\n</section>\n\n<!-- ── INTRO ── -->\n<section class=\"sec fade-in\">\n  <div class=\"intro-grid\">\n    <p class=\"intro-big\">Not just a colouring book. A reason to <span class=\"ink-underline\">put your phone down</span>.</p>\n    <div>\n      <p class=\"intro-body\">There's something about picking up a pencil and just coloring that makes your brain slow down in all the right ways. No notifications. No scroll. Just you, your colors, and a cute illustration that actually makes you smile.</p>\n      <p class=\"intro-body\">Every book in the Yallcart collection is designed with adults in mind — intricate enough to keep you busy, cozy enough that you don't feel overwhelmed. Whether you're into cats, cottages, or something a little spooky, there's a vibe for you.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── WHY ── -->\n<section class=\"sec fade-in\">\n  <p class=\"why-eyebrow\">What makes them different</p>\n  <div class=\"why-row\">\n    <span class=\"why-num\" aria-hidden=\"true\">01</span>\n    <div>\n      <p class=\"why-title\">Thick pages that don't bleed</p>\n      <p class=\"why-body\">Each page is printed on quality paper so your markers stay exactly where you put them — no bleed-through, no frustration.</p>\n    </div>\n  </div>\n  <div class=\"why-row\">\n    <span class=\"why-num\" aria-hidden=\"true\">02</span>\n    <div>\n      <p class=\"why-title\">Illustrations actually designed for adults</p>\n      <p class=\"why-body\">Detailed, expressive designs — from cozy cottages to mystical buddies to chill girl moments — that keep you genuinely absorbed.</p>\n    </div>\n  </div>\n  <div class=\"why-row\">\n    <span class=\"why-num\" aria-hidden=\"true\">03</span>\n    <div>\n      <p class=\"why-title\">The gift that actually gets used</p>\n      <p class=\"why-body\">Something personal, creative, and genuinely useful. It shows you thought about it — because you kind of did.</p>\n    </div>\n  </div>\n  <div class=\"why-row\">\n    <span class=\"why-num\" aria-hidden=\"true\">04</span>\n    <div>\n      <p class=\"why-title\">No experience needed</p>\n      <p class=\"why-body\">You don't need to be an artist. You just need colors and a bit of time. The illustrations guide you — just follow what looks right.</p>\n    </div>\n  </div>\n</section>\n\n<!-- ── BOOKS GRID ── -->\n<section class=\"sec fade-in\">\n  <h2 class=\"books-h\">Find your vibe</h2>\n  <p class=\"books-sub\">16 unique books, each with its own world. Cozy, spooky, dreamy, silly — there's one for every mood and every person on your list.</p>\n  <div class=\"books-grid\">\n    <div class=\"bk\" style=\"background:var(--sage-light)\"><div class=\"bk-thumb\">🌿</div><p class=\"bk-name\">Cozy Vibes</p><p class=\"bk-mood\">Warm, calm, made for slow evenings</p><div class=\"bk-price\"><span class=\"bk-p\">$11.99</span><span class=\"bk-was\">$18</span><span class=\"bk-off\">33% off</span></div></div>\n    <div class=\"bk\" style=\"background:var(--blush)\"><div class=\"bk-thumb\">🎃</div><p class=\"bk-name\">Spooky Cutie</p><p class=\"bk-mood\">Cute meets creepy — hauntingly good</p><div class=\"bk-price\"><span class=\"bk-p\">$11.99</span><span class=\"bk-was\">$18</span><span class=\"bk-off\">33% off</span></div></div>\n    <div class=\"bk\" style=\"background:var(--lavender)\"><div class=\"bk-thumb\">💜</div><p class=\"bk-name\">Self Care</p><p class=\"bk-mood\">For the girl who needs a quiet moment</p><div class=\"bk-price\"><span class=\"bk-p\">$11.99</span><span class=\"bk-was\">$18</span><span class=\"bk-off\">33% off</span></div></div>\n    <div class=\"bk\" style=\"background:var(--sun)\"><div class=\"bk-thumb\">🐱</div><p class=\"bk-name\">The Little Cat</p><p class=\"bk-mood\">Soft, sweet, impossibly cute</p><div class=\"bk-price\"><span class=\"bk-p\">$11.99</span><span class=\"bk-was\">$18</span><span class=\"bk-off\">33% off</span></div></div>\n    <div class=\"bk\" style=\"background:var(--sage-light)\"><div class=\"bk-thumb\">🏡</div><p class=\"bk-name\">Cozy Cottage Life</p><p class=\"bk-mood\">Dreamy countryside energy</p><div class=\"bk-price\"><span class=\"bk-p\">$11.99</span><span class=\"bk-was\">$18</span><span class=\"bk-off\">33% off</span></div></div>\n    <div class=\"bk\" style=\"background:var(--lavender)\"><div class=\"bk-thumb\">✨</div><p class=\"bk-name\">Mystical Buddies</p><p class=\"bk-mood\">Magical, whimsical, otherworldly</p><div class=\"bk-price\"><span class=\"bk-p\">$11.99</span><span class=\"bk-was\">$18</span><span class=\"bk-off\