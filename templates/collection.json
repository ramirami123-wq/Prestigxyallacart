t-size:11px;color:var(--muted);width:10px;text-align:right;}\n.bar-track{width:120px;height:5px;background:var(--border);border-radius:10px;overflow:hidden;}\n.bar-fill{height:100%;border-radius:10px;background:var(--ink);}\n\n/* ── REVIEW CARDS ── */\n.reviews-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;}\n.rv{border-radius:14px;padding:20px 18px;}\n.rv-stars{display:flex;gap:3px;margin-bottom:10px;}\n.rv-star{width:13px;height:13px;}\n.rv-text{font-size:13px;line-height:1.7;margin-bottom:14px;}\n.rv-foot{display:flex;align-items:center;gap:10px;}\n.rv-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;flex-shrink:0;}\n.rv-name{font-size:12px;font-weight:500;}\n.rv-loc{font-size:11px;margin-top:1px;}\n.rv-book{display:inline-block;font-size:10px;padding:3px 9px;border-radius:20px;margin-bottom:10px;font-weight:500;}\n\n/* color themes — reviews */\n.rv-sage{background:var(--sage-light);}\n.rv-sage .rv-text,.rv-sage .rv-name{color:#2A4F3A;}\n.rv-sage .rv-loc{color:var(--sage);}\n.rv-sage .rv-book{background:rgba(61,107,79,0.15);color:var(--sage);}\n.rv-sage .rv-avatar{background:var(--sage);color:#FDF8F2;}\n\n.rv-blush{background:var(--blush);}\n.rv-blush .rv-text,.rv-blush .rv-name{color:#6B3426;}\n.rv-blush .rv-loc{color:var(--blush-dark);}\n.rv-blush .rv-book{background:rgba(196,112,90,0.15);color:var(--blush-dark);}\n.rv-blush .rv-avatar{background:var(--blush-dark);color:#FDF8F2;}\n\n.rv-lav{background:var(--lavender);}\n.rv-lav .rv-text,.rv-lav .rv-name{color:#3D2F6E;}\n.rv-lav .rv-loc{color:var(--lav-dark);}\n.rv-lav .rv-book{background:rgba(107,91,166,0.15);color:var(--lav-dark);}\n.rv-lav .rv-avatar{background:var(--lav-dark);color:#FDF8F2;}\n\n.rv-sun{background:var(--sun);}\n.rv-sun .rv-text,.rv-sun .rv-name{color:#5A3E08;}\n.rv-sun .rv-loc{color:var(--sun-dark);}\n.rv-sun .rv-book{background:rgba(160,114,10,0.15);color:var(--sun-dark);}\n.rv-sun .rv-avatar{background:var(--sun-dark);color:#FDF8F2;}\n\n/* ── GUARANTEE CARDS ── */\n.g-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:12px;}\n.gc{border-radius:14px;padding:24px 18px;}\n.gc-icon{font-size:24px;margin-bottom:12px;}\n.gc-title{font-size:13px;font-weight:500;margin-bottom:6px;}\n.gc-body{font-size:12px;line-height:1.7;}\n\n.gc-ink{background:var(--ink);}\n.gc-ink .gc-title{color:#FDF8F2;}\n.gc-ink .gc-body{color:rgba(253,248,242,0.6);}\n\n.gc-sage{background:var(--sage-light);}\n.gc-sage .gc-title{color:#2A4F3A;}\n.gc-sage .gc-body{color:var(--sage);}\n\n.gc-blush{background:var(--blush);}\n.gc-blush .gc-title{color:#6B3426;}\n.gc-blush .gc-body{color:var(--blush-dark);}\n\n.gc-lav{background:var(--lavender);}\n.gc-lav .gc-title{color:#3D2F6E;}\n.gc-lav .gc-body{color:var(--lav-dark);}\n\n.gc-sun{background:var(--sun);}\n.gc-sun .gc-title{color:#5A3E08;}\n.gc-sun .gc-body{color:var(--sun-dark);}\n\n/* ── SCROLL FADE IN ── */\n.fade-in{opacity:0;transform:translateY(20px);transition:opacity 0.55s ease,transform 0.55s ease;}\n.fade-in.visible{opacity:1;transform:none;}\n@media(prefers-reduced-motion:reduce){.fade-in{opacity:1;transform:none;}}\n</style>\n</head>\n<body>\n\n<!-- ════════════════════════════════\n     REVIEWS SECTION\n════════════════════════════════ -->\n<section class=\"sec fade-in\">\n  <p class=\"eyebrow\">What people are saying</p>\n  <h2 class=\"sec-title\">They came for the books, they stayed for the calm.</h2>\n  <p class=\"sec-sub\">Real orders, real people, real evenings well spent.</p>\n\n  <!-- Overall rating -->\n  <div class=\"overall\">\n    <div class=\"big-score\">4.9</div>\n    <div>\n      <div class=\"stars-row\" aria-label=\"4.9 out of 5 stars\">\n        <svg class=\"star\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>\n        <svg class=\"